treestock.com.au, www.treestock.com.au {
    handle /api/subscribe {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/confirm {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/preferences {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/unsubscribe {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/watch-variety {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/unwatch-variety {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/wishlist {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/wishlist-counts {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }
    handle /api/request-manage-link {
        uri strip_prefix /api
        reverse_proxy localhost:8099
    }

    # Read-only subscriber admin view. Gate with Cloudflare Access (Zero Trust)
    # at the edge; subscribe_server.py also validates the CF Access JWT so a
    # direct-to-origin request can't bypass it.
    handle /admin {
        reverse_proxy localhost:8099
    }
    handle /admin/ {
        reverse_proxy localhost:8099
    }

    # Bare /unsubscribe is referenced by older welcome emails; route it to the
    # backend (handles GET /unsubscribe) so those links don't 404. New emails use
    # the /unsubscribe.html static page.
    handle /unsubscribe {
        reverse_proxy localhost:8099
    }

    root * /opt/dale/dashboard
    encode zstd gzip
    file_server

    handle_errors {
        @404 expression {err.status_code} == 404
        rewrite @404 /404.html
        file_server
    }

    # Versioned static assets (?v=YYYYMMDD cache-busted) can cache forever.
    @versioned path /styles.css /dashboard.js /data.js
    header @versioned Cache-Control "public, max-age=31536000, immutable"
    # Everything else (HTML) stays short-lived so daily rebuilds show up.
    @unversioned not path /styles.css /dashboard.js /data.js
    header @unversioned Cache-Control "public, max-age=3600"
}

beestock.com.au, www.beestock.com.au {
    # beestock discontinued 2026-07-23 (DEC-229). Scrapers, alerts, and the
    # subscribe server are retired; pages stay up static. Subscribe endpoints
    # return 410 instead of proxying to the stopped service on :8098.
    handle /api/subscribe {
        respond "beestock is no longer updated and subscriptions are closed." 410
    }
    handle /api/unsubscribe {
        respond "beestock subscriptions are closed. All subscribers have been removed." 410
    }
    handle /unsubscribe {
        respond "beestock subscriptions are closed. All subscribers have been removed." 410
    }

    root * /opt/dale/bee-dashboard
    encode zstd gzip
    file_server

    header {
        Cache-Control "public, max-age=3600"
    }
}

stock.scion.exchange, leafscan.com.au, www.leafscan.com.au {
    redir https://treestock.com.au{uri} permanent
}

