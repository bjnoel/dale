{{ head|safe }}
{{ header|safe }}

<main class="{{ content_max_width }} mx-auto px-4 py-6">
  {{ breadcrumb|safe }}

  <h1 class="text-3xl font-bold text-green-900 mb-2">Fruit Tree and Bush Tucker Varieties for Sale in Australia</h1>
  <p class="text-gray-600 mb-4">
    Browse {{ total_varieties }} named cultivars tracked across {{ species_count }} species.
    {{ total_in_stock }} currently in stock across all Australian nurseries. Updated daily.
  </p>

  <div class="mb-6">
    <div class="flex gap-2">
      <input id="varietySearch" type="search" placeholder="Search varieties or species (e.g. Hass, Bowen, Valencia...)"
        class="flex-1 min-w-0 border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
        autocomplete="off">
      <select id="stateFilter" aria-label="Filter by state"
        class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent">
        <option value="">All states</option>
        <option value="NSW">NSW</option>
        <option value="VIC">VIC</option>
        <option value="QLD">QLD</option>
        <option value="SA">SA</option>
        <option value="WA">WA</option>
        <option value="ACT">ACT</option>
        <option value="TAS">TAS</option>
        <option value="NT">NT</option>
      </select>
    </div>
    <div class="flex flex-wrap gap-2 mt-2" id="catPills">
      <button class="cat-filter-btn active text-xs px-3 py-1.5 rounded border border-gray-300 hover:border-green-600" data-cat="all">All</button>
      <button class="cat-filter-btn text-xs px-3 py-1.5 rounded border border-gray-300 hover:border-green-600" data-cat="fruit">Fruit</button>
      <button class="cat-filter-btn text-xs px-3 py-1.5 rounded border border-gray-300 hover:border-green-600" data-cat="bush_tucker">Bush Tucker</button>
    </div>
    <p id="varietyCount" class="text-xs text-gray-400 mt-1">{{ total_varieties }} varieties across {{ species_count }} species</p>
  </div>

  <div id="noResults" class="hidden text-center py-12 text-gray-500">
    <p class="text-lg">No varieties found matching your search.</p>
    <p class="text-sm mt-1">Try a different spelling or species name, or clear the state filter.</p>
  </div>

  {%+ for s in species_view %}{{ "" }}
  <section class="mb-8" id="{{ s.sp_slug }}" data-sp="{{ s.sp_lower }}" data-category="{{ s.category }}"{% if s.is_bush_tucker %} data-bushtucker="1"{% endif %}>
    <h3 class="text-lg font-semibold text-green-900 mb-1">
      {{ s.sp_heading|safe }}{{ s.badges_html|safe }}
      <span class="text-sm font-normal text-gray-500 ml-2">{{ s.variety_count }} varieties · {{ s.in_stock_count }} in stock</span>
    </h3>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-gray-200 text-xs text-gray-400 uppercase">
            <th class="pb-1 pr-4">Variety</th>
            <th class="pb-1 pr-4">Coverage</th>
            <th class="pb-1 pr-4">Stock</th>
            <th class="pb-1">From</th>
          </tr>
        </thead>
        <tbody>
{% for v in s.rows %}
      <tr class="border-b border-gray-100 hover:bg-gray-50" data-var="{{ v.var_lower }}" data-states="{{ v.states }}">
        <td class="py-2 pr-4">
          <a href="/variety/{{ v.slug }}.html" class="text-green-800 hover:underline">{{ v.variety }}</a>
        </td>
        <td class="py-2 pr-4 text-sm text-gray-600">{{ v.n_count }} nurseries</td>
        <td class="py-2 pr-4 text-sm">{% if v.in_s > 0 %}{{ v.in_s }} in stock{% else %}<a href="/variety/{{ v.slug }}.html" class="text-amber-700 hover:underline whitespace-nowrap">&#128276; Notify me</a>{% endif %}</td>
        <td class="py-2 text-sm font-medium">{{ v.price }}</td>
      </tr>
{% endfor %}        </tbody>
      </table>
    </div>
  </section>{% endfor %}


</main>

<script>
(function() {
  const input = document.getElementById('varietySearch');
  const stateSel = document.getElementById('stateFilter');
  const countEl = document.getElementById('varietyCount');
  const noResultsEl = document.getElementById('noResults');
  const sections = document.querySelectorAll('section[data-sp]');
  const catPills = document.querySelectorAll('#catPills .cat-filter-btn');
  const totalVarieties = {{ total_varieties }};
  const totalSpecies = {{ species_count }};
  let activeCat = 'all';

  // Mirror the filter state into the address bar so a filtered view is shareable.
  // replaceState keeps it out of the back-button history; defaults are dropped.
  function syncURL() {
    const params = new URLSearchParams();
    const q = input.value.trim();
    if (q) params.set('q', q);
    if (stateSel.value) params.set('state', stateSel.value);
    if (activeCat !== 'all') params.set('cat', activeCat);
    const qs = params.toString();
    window.history.replaceState(null, '',
      window.location.pathname + (qs ? '?' + qs : '') + window.location.hash);
  }

  function applyFilters() {
    const q = input.value.toLowerCase().trim();
    const state = stateSel.value;
    let visibleVarieties = 0;
    let visibleSpecies = 0;

    sections.forEach(function(section) {
      const catOk = activeCat === 'all'
        || (activeCat === 'fruit' && section.getAttribute('data-category') === 'fruit')
        || (activeCat === 'bush_tucker' && section.getAttribute('data-bushtucker') === '1');
      if (!catOk) {
        section.style.display = 'none';
        return;
      }
      const sp = section.getAttribute('data-sp');
      const spMatch = !q || sp.includes(q);
      const rows = section.querySelectorAll('tr[data-var]');
      let rowsShown = 0;

      rows.forEach(function(row) {
        const varName = row.getAttribute('data-var');
        const searchOk = !q || spMatch || varName.includes(q);
        const stateOk = !state || (' ' + row.getAttribute('data-states') + ' ').includes(' ' + state + ' ');
        if (searchOk && stateOk) {
          row.style.display = '';
          rowsShown++;
        } else {
          row.style.display = 'none';
        }
      });

      if (rowsShown > 0) {
        section.style.display = '';
        visibleVarieties += rowsShown;
        visibleSpecies++;
      } else {
        section.style.display = 'none';
      }
    });

    if (!q && !state && activeCat === 'all') {
      countEl.textContent = totalVarieties + ' varieties across ' + totalSpecies + ' species';
      noResultsEl.classList.add('hidden');
    } else if (visibleVarieties === 0) {
      countEl.textContent = 'No matches found';
      noResultsEl.classList.remove('hidden');
    } else {
      const where = state ? ' shippable to ' + state : '';
      countEl.textContent = visibleVarieties + ' varieties across ' + visibleSpecies + ' species' + where;
      noResultsEl.classList.add('hidden');
    }
    syncURL();
  }

  input.addEventListener('input', applyFilters);
  stateSel.addEventListener('change', applyFilters);
  catPills.forEach(function(btn) {
    btn.addEventListener('click', function() {
      catPills.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeCat = btn.getAttribute('data-cat');
      applyFilters();
    });
  });

  // Restore filter state from the URL (q / state / cat) so shared links land filtered.
  (function restoreFromURL() {
    const params = new URLSearchParams(window.location.search);
    let restored = false;
    if (params.has('q')) { input.value = params.get('q'); restored = true; }
    const st = params.get('state');
    if (st && stateSel.querySelector('option[value="' + CSS.escape(st) + '"]')) {
      stateSel.value = st;
      restored = true;
    }
    const cat = params.get('cat');
    if (cat === 'fruit' || cat === 'bush_tucker') {
      activeCat = cat;
      catPills.forEach(function(b) { b.classList.toggle('active', b.getAttribute('data-cat') === cat); });
      restored = true;
    }
    if (restored) applyFilters();  // also re-canonicalises the URL via syncURL()
  })();
})();
</script>

{{ footer|safe }}

</body>
</html>