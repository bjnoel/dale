{{ head|safe }}
{{ header|safe }}

<main class="{{ content_max_width }} mx-auto px-4 py-6">

  <!-- Hero -->
  <div class="mb-6">
    {{ breadcrumb|safe }}
    <h1 class="text-3xl font-bold text-green-900 mb-1">{{ name }} Trees</h1>
    <p class="text-gray-500 italic mb-3">{{ latin }}{% if region %} ({{ region }}){% endif %}</p>
    <div class="flex flex-wrap gap-3 text-sm">
      <span class="px-3 py-1 bg-green-50 text-green-800 rounded-full font-medium">{{ in_stock_count }} varieties in stock</span>
      {{ price_badge|safe }}
      <span class="px-3 py-1 bg-gray-50 text-gray-600 rounded-full">{{ nursery_count }} nurseries</span>
      {{ rarity_badge_html|safe }}
    </div>
  </div>

  {{ when_to_buy_html|safe }}

  <!-- Where to Buy -->
  <section class="mb-8">
    <h3 class="text-lg font-semibold text-gray-800 mb-3">Where to buy {{ name }} trees in Australia</h3>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-gray-200 text-xs text-gray-500 uppercase">
            <th class="pb-2 pr-4">Nursery</th>
            <th class="pb-2 pr-4">Availability</th>
            <th class="pb-2">Ships to</th>
          </tr>
        </thead>
        <tbody>
{% for n in nursery_view %}
      <tr class="border-b border-gray-100">
        <td class="py-2 pr-4 text-sm"><a href="/nursery/{{ n.key }}.html" class="font-medium text-gray-900 hover:text-green-700 hover:underline">{{ n.name }}</a></td>
        <td class="py-2 pr-4 text-sm"><a href="#listings" data-nursery-filter="{{ n.key }}" data-nursery-name="{{ n.name }}" class="{{ n.avail_color }} hover:underline" title="Show only {{ n.name }} listings below">{{ n.avail_text }} ({{ n.total }} listed)</a></td>
        <td class="py-2 text-xs text-gray-500">{{ n.ships }}</td>
      </tr>
{% endfor %}        </tbody>
      </table>
    </div>
  </section>

{{ watch_box_html|safe }}

{% if variety_view %}
  <!-- Varieties -->
  <section class="mb-8" id="varieties">
    <h3 class="text-lg font-semibold text-gray-800 mb-3">{{ name }} varieties ({{ variety_view|length }})</h3>
    <div id="varietyChips" class="flex flex-wrap gap-2 overflow-hidden" style="max-height:94px">
{% for v in variety_view %}
      <a href="/variety/{{ v.slug }}.html" class="inline-flex items-center gap-1 px-2.5 py-1 bg-gray-50 border border-gray-200 rounded-full text-xs text-gray-700 hover:border-green-400 hover:text-green-800">{% if v.in_stock %}<span class="text-green-600">&#9679;</span>{% else %}<span class="text-gray-400">&#9675;</span>{% endif %}{{ v.name }}</a>
{% endfor %}
    </div>
    <button id="varietyToggle" type="button" class="hidden mt-2 text-sm text-green-700 hover:underline">Show all {{ variety_view|length }} varieties</button>
{% if notable_view %}
    <div class="mt-4" id="notable-varieties">
      <h4 class="text-sm font-semibold text-gray-700 mb-2">Notable varieties in stock</h4>
      <ul class="text-sm space-y-1.5">
{% for v in notable_view %}
        <li><a href="/variety/{{ v.slug }}.html" class="text-green-700 font-medium hover:underline">{{ v.name }}</a><span class="text-gray-600"> {{ v.excerpt }}</span></li>
{% endfor %}
      </ul>
    </div>
{% endif %}
  </section>
{% endif %}

  {{ description_html|safe }}

  {{ state_links_html|safe }}

  {{ related_species_html|safe }}

  <!-- All Listings -->
  <section class="mb-8" id="listings">
    <h3 class="text-lg font-semibold text-gray-800 mb-3">All {{ name }} listings ({{ total_count }})</h3>
    <div id="listingsFilterBar" class="hidden mb-3 px-3 py-2 bg-green-50 border border-green-200 rounded-lg text-sm text-green-900">
      Showing <span id="filterCount"></span> listings from <span id="filterName"></span>.
      <a href="#listings" id="filterClear" class="text-green-700 underline ml-1">Clear filter</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-gray-200 text-xs text-gray-500 uppercase">
            <th class="pb-2 pr-3">Variety</th>
            <th class="pb-2 pr-3">Nursery</th>
            <th class="pb-2 pr-3">Price</th>
            <th class="pb-2">Status</th>
          </tr>
        </thead>
        <tbody>
{% for p in product_view %}
      <tr class="border-b border-gray-100 hover:bg-gray-50" data-nursery="{{ p.nursery_key }}">
        <td class="py-2 pr-3 text-sm">{% if p.has_url %}<a href="{{ p.nursery_url }}" target="_blank" rel="noopener" class="hover:text-green-700 hover:underline">{{ p.title }}</a>{% else %}{{ p.title }}{% endif %}{{ p.alert_link|safe }}</td>
        <td class="py-2 pr-3 text-xs text-gray-500">{{ p.nursery_name }}</td>
        <td class="py-2 pr-3 text-sm font-medium">{% if p.price %}${{ '%.2f'|format(p.price) }}{% else %}-{% endif %}</td>
        <td class="py-2">{% if p.available %}<span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full">In stock</span>{% else %}<span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">Out of stock</span>{% endif %}</td>
      </tr>
{% endfor %}        </tbody>
      </table>
    </div>
  </section>

  {{ variety_cta|safe }}

  {{ treesmith_promo|safe }}

</main>

<script>
(function() {
  // Variety chip cloud: reveal the expander only when chips overflow the
  // 3-row clamp, so small species never show a pointless toggle.
  var chips = document.getElementById('varietyChips');
  var toggle = document.getElementById('varietyToggle');
  if (chips && toggle && chips.scrollHeight > chips.clientHeight + 1) {
    toggle.classList.remove('hidden');
    var showAllLabel = toggle.textContent;
    toggle.addEventListener('click', function() {
      if (chips.style.maxHeight) {
        chips.style.maxHeight = '';
        toggle.textContent = 'Show fewer varieties';
      } else {
        chips.style.maxHeight = '94px';
        toggle.textContent = showAllLabel;
      }
    });
  }

  // Where-to-buy availability links filter the listings table to one nursery.
  // Without JS they degrade to plain #listings anchor jumps.
  var bar = document.getElementById('listingsFilterBar');
  var countEl = document.getElementById('filterCount');
  var nameEl = document.getElementById('filterName');
  var rows = document.querySelectorAll('#listings tbody tr[data-nursery]');
  document.querySelectorAll('a[data-nursery-filter]').forEach(function(link) {
    link.addEventListener('click', function() {
      var key = link.getAttribute('data-nursery-filter');
      var shown = 0;
      rows.forEach(function(r) {
        var match = r.getAttribute('data-nursery') === key;
        r.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      countEl.textContent = shown;
      nameEl.textContent = link.getAttribute('data-nursery-name') || key;
      bar.classList.remove('hidden');
    });
  });
  var clear = document.getElementById('filterClear');
  if (clear) clear.addEventListener('click', function(e) {
    e.preventDefault();
    rows.forEach(function(r) { r.style.display = ''; });
    bar.classList.add('hidden');
  });
})();
</script>

{{ footer|safe }}
{{ watch_script|safe }}
</body>
</html>
