{
  "version": "2.0",
  "schedule": {
    "cron_time": "0 * * * *",
    "digest_time": "0 22 * * *",
    "timezone_note": "Runner: every hour. Digest: 22:00 UTC = 06:00 AWST"
  },
  "budget": {
    "max_session_duration_minutes": 60,
    "max_turns": 200
  },
  "linear": {
    "team": "Dale",
    "max_backlog": 40
  },
  "notifications": {
    "from_email": "dale@mail.walkthrough.au",
    "to_email": "b@bjnoel.com"
  },
  "paths": {
    "repo": "/opt/dale/repo",
    "data": "/opt/dale/data",
    "autonomous": "/opt/dale/autonomous",
    "secrets": "/opt/dale/secrets",
    "scrapers": "/opt/dale/scrapers"
  },
  "circuit_breakers": {
    "max_consecutive_failures": 3
  },
  "reflection": {
    "category_streak_threshold": 3,
    "parent_streak_threshold": 4,
    "revenue_alarm_days_threshold": 14,
    "lookback_sessions": 5
  }
}
