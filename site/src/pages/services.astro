---
import Base from '../layouts/Base.astro';
---

<Base
  title="The Walkthrough Audit — What's Included"
  description="What an AI efficiency audit from Walkthrough involves: the visit, the analysis, and the deliverable. Perth small businesses."
>
  <header>
    <nav>
      <a href="/" class="logo">Walk<span>through</span></a>
      <div class="nav-links">
        <a href="/#how">How It Works</a>
        <a href="/#pricing">Pricing</a>
        <a href="/log">Public Log</a>
        <a href="mailto:hello@walkthrough.au?subject=Booking%20an%20Assessment" class="btn-nav">Book Assessment</a>
      </div>
    </nav>
  </header>

  <main>

    <section class="hero">
      <div class="container">
        <div class="eyebrow">Service Detail / What You Get</div>
        <h1>The Walkthrough Audit</h1>
        <p class="hero-sub">
          A one-off service for Perth small businesses. We visit, we look, we analyse, and we tell you exactly what to change and why.
          No jargon. No fluff. Actionable findings delivered in person.
        </p>
        <div class="hero-meta">
          <span>$199 flat fee</span>
          <span>Perth metro area</span>
          <span>Results within 48 hours</span>
        </div>
      </div>
    </section>

    <section class="process-detail">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Process / Timeline</div>
          <h2 class="section-title">From booking to findings</h2>
        </div>

        <div class="timeline">
          <div class="timeline-item">
            <div class="tl-marker">Day 1</div>
            <div class="tl-content">
              <h3>Book</h3>
              <p>
                Email us at <a href="mailto:hello@walkthrough.au">hello@walkthrough.au</a>.
                Tell us your business name, suburb, and what you sell or do.
                We confirm a visit time within 24 hours. No intake forms, no onboarding call.
              </p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="tl-marker">Day 2-5</div>
            <div class="tl-content">
              <h3>The Visit</h3>
              <p>
                Ben spends approximately one hour at your business.
                He walks through your operations, asks questions, and takes notes.
                No laptop, no presentation. Just observation and conversation.
                The goal is to see how things actually work, not how you describe them on paper.
              </p>
              <div class="visit-list">
                <div class="visit-item">
                  <span class="vi-label">We observe</span>
                  <span>How your team handles repetitive tasks and manual processes</span>
                </div>
                <div class="visit-item">
                  <span class="vi-label">We check</span>
                  <span>Your online presence: Google Business Profile, website, social accounts</span>
                </div>
                <div class="visit-item">
                  <span class="vi-label">We ask</span>
                  <span>What takes the most time? What breaks? What do customers complain about?</span>
                </div>
                <div class="visit-item">
                  <span class="vi-label">We note</span>
                  <span>Your software stack, tools you are using, tools you are not using but should be</span>
                </div>
              </div>
            </div>
          </div>
          <div class="timeline-item">
            <div class="tl-marker">Day 5-7</div>
            <div class="tl-content">
              <h3>The Analysis</h3>
              <p>
                After the visit, Dale (the AI half of the partnership) runs a full analysis.
                This covers your online presence, competitor benchmarking, Google search visibility,
                review patterns, and anything flagged during the visit.
                The result is a ranked list of specific, actionable findings.
              </p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="tl-marker">Day 7-10</div>
            <div class="tl-content">
              <h3>The Deliverable + Walkthrough</h3>
              <p>
                You get a short written report (typically 3-5 findings, 2-4 pages).
                Ben walks you through it in person or over a call (30 minutes).
                The report is yours to keep and share with your team.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="deliverable">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Output / Deliverable Format</div>
          <h2 class="section-title">What the report looks like</h2>
        </div>
        <p class="section-intro">
          Each finding in the report has the same structure. This makes it easy to read, share with your team, and prioritise.
        </p>
        <div class="report-anatomy">
          <div class="report-field">
            <span class="rf-label">Finding</span>
            <span class="rf-desc">One sentence describing the problem or opportunity</span>
          </div>
          <div class="report-field">
            <span class="rf-label">Impact</span>
            <span class="rf-desc">What it is costing you in time, money, or customers</span>
          </div>
          <div class="report-field">
            <span class="rf-label">Recommendation</span>
            <span class="rf-desc">The specific change to make, with tool names and steps where relevant</span>
          </div>
          <div class="report-field">
            <span class="rf-label">Effort</span>
            <span class="rf-desc">Low, medium, or high. Whether you can do it yourself or need help</span>
          </div>
          <div class="report-field">
            <span class="rf-label">Priority</span>
            <span class="rf-desc">Do this week, do this month, or consider later</span>
          </div>
        </div>
      </div>
    </section>

    <section class="examples">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Example Findings</div>
          <h2 class="section-title">The kinds of things we find</h2>
        </div>
        <p class="section-intro">
          These are realistic examples of findings from a typical retail or professional services business.
          They are not from any specific client.
        </p>

        <div class="example-grid">

          <div class="example-card">
            <div class="ex-badge">Online Presence</div>
            <div class="ex-finding">Google Business Profile is missing your trading hours and has no recent photos</div>
            <div class="ex-impact">
              <span class="ex-label">Impact</span>
              Customers searching for you on Google Maps see incomplete information and may choose a competitor.
              Google Business Profiles with complete info receive 70% more visits in search results.
            </div>
            <div class="ex-rec">
              <span class="ex-label">Recommendation</span>
              Update hours, add 3-5 product or interior photos, and ask your 3 most loyal customers to leave a review this week.
            </div>
            <div class="ex-meta">
              <span class="ex-effort low">Low effort</span>
              <span class="ex-priority">Do this week</span>
            </div>
          </div>

          <div class="example-card">
            <div class="ex-badge">Manual Process</div>
            <div class="ex-finding">Inventory updates are done manually in a spreadsheet and take 2-3 hours per week</div>
            <div class="ex-impact">
              <span class="ex-label">Impact</span>
              Roughly 100-150 hours per year spent on data entry that your POS system can handle automatically.
              Manual updates also mean stockouts or overselling when a sale is missed.
            </div>
            <div class="ex-rec">
              <span class="ex-label">Recommendation</span>
              Your current POS has a stock sync feature that is not enabled. Takes 20 minutes to set up.
              We can walk you through it or set it up as part of the implementation support.
            </div>
            <div class="ex-meta">
              <span class="ex-effort low">Low effort</span>
              <span class="ex-priority">Do this week</span>
            </div>
          </div>

          <div class="example-card">
            <div class="ex-badge">Customer Communications</div>
            <div class="ex-finding">Appointment reminders are sent manually by text from a personal phone</div>
            <div class="ex-impact">
              <span class="ex-label">Impact</span>
              Typically 30-60 minutes per day and a high no-show rate compared to automated reminder systems.
              Using a personal number also creates issues when staff changes.
            </div>
            <div class="ex-rec">
              <span class="ex-label">Recommendation</span>
              Switch to an automated reminder tool (Acuity, Calendly, or a booking plugin for your existing website).
              Most options cost $15-30/month and reduce no-shows by 30-60%.
            </div>
            <div class="ex-meta">
              <span class="ex-effort med">Medium effort</span>
              <span class="ex-priority">Do this month</span>
            </div>
          </div>

          <div class="example-card">
            <div class="ex-badge">Online Sales</div>
            <div class="ex-finding">Your website has no online shop despite most competitors offering online ordering</div>
            <div class="ex-impact">
              <span class="ex-label">Impact</span>
              Customers who find you online cannot purchase without calling or visiting.
              Search data shows 200-400 monthly searches for your product category in Perth.
            </div>
            <div class="ex-rec">
              <span class="ex-label">Recommendation</span>
              A basic Shopify store (from $49/month) would let you sell online and manage stock in one place.
              Your top 10 products are enough to start. We can build a demo store to show you what it looks like.
            </div>
            <div class="ex-meta">
              <span class="ex-effort med">Medium effort</span>
              <span class="ex-priority">Do this month</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="scope">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Scope / Coverage Areas</div>
          <h2 class="section-title">What we look at</h2>
        </div>
        <div class="scope-grid">
          <div class="scope-item">
            <div class="scope-icon">01</div>
            <h3>Online Presence</h3>
            <p>Google Business Profile, website, social media, online reviews, search visibility. We check what customers see before they walk through your door.</p>
          </div>
          <div class="scope-item">
            <div class="scope-icon">02</div>
            <h3>Operations and Admin</h3>
            <p>Repetitive manual tasks, spreadsheet workflows, data entry, paperwork. The tasks that could be automated or eliminated.</p>
          </div>
          <div class="scope-item">
            <div class="scope-icon">03</div>
            <h3>Customer Communications</h3>
            <p>How you handle enquiries, bookings, reminders, follow-ups, and complaints. Where delays or manual steps cause friction.</p>
          </div>
          <div class="scope-item">
            <div class="scope-icon">04</div>
            <h3>Software and Tools</h3>
            <p>What you are paying for, what you are not using, what you are missing. Unused features in tools you already own are the most common quick wins.</p>
          </div>
          <div class="scope-item">
            <div class="scope-icon">05</div>
            <h3>Payments and Bookings</h3>
            <p>How customers pay, how appointments are booked, how deposits are handled. Friction in these flows costs you customers.</p>
          </div>
          <div class="scope-item">
            <div class="scope-icon">06</div>
            <h3>AI Opportunities</h3>
            <p>Where AI tools (ChatGPT, Copilot, specialised products) can save meaningful time in your specific business context. No hype, just what actually applies to you.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing" class="pricing">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Pricing / What It Costs</div>
          <h2 class="section-title">Simple, no-surprise pricing</h2>
        </div>
        <p class="section-intro">
          No discovery calls, no scopes of work, no proposals. One fixed price to see if there is value here. Then optional ongoing support if you want to act on the findings.
        </p>

        <div class="pricing-grid">

          <div class="pricing-card pricing-main">
            <div class="pricing-eyebrow">Step 1</div>
            <div class="pricing-name">The Walkthrough Audit</div>
            <div class="pricing-amount">$199</div>
            <div class="pricing-freq">one-off, paid after the visit</div>
            <div class="pricing-divider"></div>
            <ul class="pricing-includes">
              <li>One-hour in-person visit to your business</li>
              <li>Full analysis of your operations and online presence</li>
              <li>Written report (3-5 specific, prioritised findings)</li>
              <li>30-minute walkthrough session to review findings</li>
              <li>Yours to keep and share with your team</li>
            </ul>
            <a href="mailto:hello@walkthrough.au?subject=Booking%20an%20Assessment" class="pricing-cta">Book an assessment</a>
          </div>

          <div class="pricing-card pricing-optional">
            <div class="pricing-eyebrow">Step 2 (optional)</div>
            <div class="pricing-name">Implementation Support</div>
            <div class="pricing-amount">from $99<span class="pricing-per">/month</span></div>
            <div class="pricing-freq">no lock-in, cancel any time</div>
            <div class="pricing-divider"></div>
            <ul class="pricing-includes">
              <li>We help you implement the report recommendations</li>
              <li>Set up tools, configure software, train your team</li>
              <li>Monthly check-in to review progress</li>
              <li>Ongoing advice as your situation changes</li>
              <li>Most clients need 1-3 months to act on findings</li>
            </ul>
            <div class="pricing-note">Only available after completing the audit. Price depends on scope.</div>
          </div>

        </div>

        <div class="pricing-guarantee">
          <span class="pg-label">Our guarantee</span>
          If the audit does not surface at least one finding worth acting on, you pay nothing.
        </div>

      </div>
    </section>

    <section class="good-fit">
      <div class="container">
        <div class="section-header">
          <div class="field-label">Fit / Who This Is For</div>
          <h2 class="section-title">Is this right for your business?</h2>
        </div>
        <div class="fit-grid">
          <div class="fit-col fit-yes">
            <div class="fit-header">Good fit</div>
            <ul>
              <li>Perth metro area (we visit in person)</li>
              <li>5-20 staff, owner-operated or small team</li>
              <li>Retail, trades, professional services, hospitality</li>
              <li>You feel like technology is passing you by</li>
              <li>You want practical changes, not a strategy document</li>
              <li>You have never had an outside perspective on your operations</li>
            </ul>
          </div>
          <div class="fit-col fit-no">
            <div class="fit-header">Not a good fit</div>
            <ul>
              <li>Outside Perth (we cannot visit)</li>
              <li>Large organisations with dedicated IT/ops teams</li>
              <li>Businesses looking for a full digital transformation project</li>
              <li>Businesses that want a lengthy consulting engagement</li>
              <li>Businesses looking for someone to implement everything for them from day one</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="contact-section">
      <div class="container">
        <div class="contact-box">
          <div class="contact-eyebrow">Next Step</div>
          <h2 class="contact-headline">Book an assessment</h2>
          <p class="contact-sub">
            Email us with your business name and suburb. We will confirm a visit time within 24 hours.
          </p>
          <a href="mailto:hello@walkthrough.au?subject=Booking%20an%20Assessment" class="email-link">hello@walkthrough.au</a>
          <div class="contact-meta">
            <span>$199 flat fee</span>
            <span>Perth metro</span>
            <span>No lock-in</span>
          </div>
        </div>
      </div>
    </section>

  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-attribution">
        Assessment by: <strong>Ben (Human)</strong> + <strong>Dale (AI)</strong> &nbsp;&middot;&nbsp; Perth, WA
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/log">Public Log</a>
      </div>
    </div>
  </footer>

</Base>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 0 24px; }

  .field-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-mid);
  }

  /* Navigation */
  header {
    border-bottom: 1px solid var(--gray-border);
    background: rgba(255,255,255,0.94);
    backdrop-filter: blur(4px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    max-width: 960px;
    margin: 0 auto;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--black);
    text-transform: uppercase;
  }
  .logo span { color: var(--green); }
  .logo:hover { text-decoration: none; }

  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-dark);
  }

  .btn-nav {
    background: var(--green) !important;
    color: white !important;
    padding: 8px 16px;
    border: 1px solid var(--green);
  }
  .btn-nav:hover { background: #0f3d22 !important; text-decoration: none !important; }

  /* Hero */
  .hero {
    padding: 72px 0 64px;
    border-bottom: 2px solid var(--gray-border);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid var(--green-rule);
    background: var(--green-light);
    padding: 4px 10px;
    display: inline-block;
    margin-bottom: 20px;
  }

  .hero h1 {
    font-family: var(--font-mono);
    font-size: 36px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--gray-dark);
    max-width: 580px;
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .hero-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--gray-mid);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  /* Section scaffolding */
  section { padding: 72px 0; border-bottom: 1px solid var(--gray-border); }
  .section-header { margin-bottom: 40px; }
  .section-title {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    margin-top: 8px;
    letter-spacing: -0.01em;
  }
  .section-intro {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--gray-dark);
    max-width: 640px;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  /* Process / Timeline */
  .timeline {
    border: 1px solid var(--gray-border);
    background: var(--white);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0;
    border-bottom: 1px solid var(--gray-border);
  }

  .timeline-item:last-child { border-bottom: none; }

  .tl-marker {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    padding: 28px 16px;
    border-right: 1px solid var(--gray-border);
    background: var(--green-light);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    text-align: center;
  }

  .tl-content {
    padding: 28px 28px;
  }

  .tl-content h3 {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--black);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
  }

  .tl-content p {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--gray-dark);
    line-height: 1.65;
    margin-bottom: 0;
  }

  .visit-list {
    margin-top: 16px;
    border: 1px solid var(--gray-border);
  }

  .visit-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--gray-border);
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--gray-dark);
    align-items: baseline;
  }

  .visit-item:last-child { border-bottom: none; }

  .vi-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-mid);
    white-space: nowrap;
  }

  /* Deliverable anatomy */
  .deliverable { background: var(--gray-bg); }

  .report-anatomy {
    border: 1px solid var(--gray-border);
    background: var(--white);
  }

  .report-field {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--gray-border);
    align-items: baseline;
  }

  .report-field:last-child { border-bottom: none; }

  .rf-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
  }

  .rf-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--gray-dark);
    line-height: 1.5;
  }

  /* Examples */
  .example-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--gray-border);
    background: var(--white);
  }

  .example-card {
    padding: 24px;
    border-bottom: 1px solid var(--gray-border);
    border-right: 1px solid var(--gray-border);
  }

  .example-card:nth-child(2n) { border-right: none; }
  .example-card:nth-last-child(-n+2) { border-bottom: none; }

  .ex-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    background: var(--green-light);
    border: 1px solid var(--green-rule);
    padding: 2px 8px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .ex-finding {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    line-height: 1.4;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }

  .ex-impact, .ex-rec {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--gray-dark);
    line-height: 1.55;
    margin-bottom: 12px;
  }

  .ex-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-mid);
    display: block;
    margin-bottom: 3px;
  }

  .ex-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .ex-effort, .ex-priority {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid;
  }

  .ex-effort.low { color: #1a5632; border-color: var(--green-rule); background: var(--green-light); }
  .ex-effort.med { color: #7c4e00; border-color: #f0d890; background: #fffbeb; }
  .ex-priority { color: var(--gray-mid); border-color: var(--gray-border); background: var(--gray-bg); }

  /* Scope */
  .scope { background: var(--gray-bg); }

